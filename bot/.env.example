# ============================================================
# VPNHub Bot — environment variable template
# Copy this file to bot/.env and fill in real values.
# NEVER commit bot/.env to version control.
# See docs/env.md for full variable documentation.
# ============================================================

# ------------------------------------------------------------
# Core bot configuration (required)
# ------------------------------------------------------------
TG_TOKEN=CHANGE_ME                  # Telegram bot token from @BotFather
ADMIN_TG_ID=CHANGE_ME               # Telegram user ID of the bot admin
NAME=VPNHub                         # Bot display name
LANGUAGES=ru,en                     # Comma-separated supported language codes

# ------------------------------------------------------------
# Channel follow gating (required when CHECK_FOLLOW=1)
# ------------------------------------------------------------
CHECK_FOLLOW=0                      # 1 = enforce channel subscription check
ID_CHANNEL=CHANGE_ME                # Telegram channel ID (integer)
LINK_CHANNEL=CHANGE_ME              # Channel invite link
NAME_CHANNEL=CHANGE_ME              # Channel display name

# ------------------------------------------------------------
# Pricing and limits
# ------------------------------------------------------------
PRICE_SWITCH_LOCATION=0             # Stars/coins cost to change server location
MONTH_COST=500,900,1700             # Comma-separated monthly plan prices (kopecks or stars)
TRIAL_PERIOD=259200                 # Trial period in seconds (default: 3 days)
FREE_SWITCH_LOCATION=1              # Number of free location switches per user
FREE_SERVER=0                       # 1 = free VPN servers enabled
LIMIT_GB_FREE=5                     # GB limit for free servers (requires FREE_SERVER=1)
LIMIT_IP=0                          # Max IPs per user (0 = unlimited)
LIMIT_GB=0                          # GB limit per paid plan (0 = unlimited)

# ------------------------------------------------------------
# Referral / payouts
# ------------------------------------------------------------
REFERRAL_DAY=30                     # Referral window in days
REFERRAL_PERCENT=20                 # Percent of payment returned to referrer
MINIMUM_WITHDRAWAL_AMOUNT=100       # Minimum withdrawal threshold

# ------------------------------------------------------------
# Payment providers (leave empty string if provider not used)
# ------------------------------------------------------------
YOOMONEY_TOKEN=
YOOMONEY_WALLET=

LAVA_TOKEN_SECRET=
LAVA_ID_PROJECT=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

CRYPTOMUS_KEY=
CRYPTOMUS_UUID=

HELEKET_KEY=
HELEKET_UUID=

WATA_TOKEN_CARD=
WATA_TOKEN_SBP=
WATA_TOKEN_VISA=

CRYPTO_BOT_API=

# ------------------------------------------------------------
# Database (Postgres)
# ------------------------------------------------------------
POSTGRES_DB=VPNHubBotDB
POSTGRES_USER=vpnhub
POSTGRES_PASSWORD=CHANGE_ME         # Rotate immediately — never use default

# ------------------------------------------------------------
# PGAdmin (optional, only needed if pgadmin service is used)
# ------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# ------------------------------------------------------------
# NATS
# ------------------------------------------------------------
NATS_SERVERS=nats://nats:4222       # Comma-separated NATS URLs (preferred)
NATS_URL=nats://nats:4222           # Legacy fallback (NATS_SERVERS takes precedence)

# ------------------------------------------------------------
# Runtime / debug
# ------------------------------------------------------------
DEBUG=False                         # True = use sqlite + debug mode (local only)

# ------------------------------------------------------------
# Server health-check performance tuning
# ------------------------------------------------------------
SERVER_CHECK_TIMEOUT_SEC=8          # Seconds before a server check times out
SERVER_CHECK_CONCURRENCY=5          # Max parallel server checks

# ------------------------------------------------------------
# Feature flags
# ------------------------------------------------------------
IMPORT_DB=0                         # 1 = import initial DB dump on startup
SHOW_DONATE=0                       # 1 = show donate buttons
IS_WORK_EDIT_KEY=1                  # 1 = enable edit-key workflow
TG_STARS=                           # Internal stars endpoint token (leave empty if unused)
TG_STARS_DEV=                       # Internal stars dev flag (leave empty if unused)
FONT_TEMPLATE=                      # Optional font/template name for generated images
